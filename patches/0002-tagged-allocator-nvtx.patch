diff --color -ruN a/libs/cuda_modules/alloc_log.cpp b/libs/cuda_modules/alloc_log.cpp
--- a/libs/cuda_modules/alloc_log.cpp	1970-01-01 05:30:00.000000000 +0530
+++ b/libs/cuda_modules/alloc_log.cpp	2026-07-04 13:50:53.703326777 +0530
@@ -0,0 +1,122 @@
+
+/*
+ * Instrumentation-only allocation journal (profiling; not part of upstream cuVSLAM).
+ * See alloc_log.h. Log format (CSV, one record per line):
+ *   #cuvslam-alloc-log,v1                     header
+ *   M,<start>-<end> r-xp ... <path>           /proc/self/maps executable rows
+ *                                             (at first use and again at exit;
+ *                                             consumers dedup) - undoes ASLR
+ *   A,<t_us>,<ptr>,<bytes>,<kind>,<pc>,...    allocation + host backtrace PCs
+ *   F,<t_us>,<ptr>                            free
+ * Timestamps are CLOCK_MONOTONIC microseconds.
+ */
+
+#include "cuda_modules/alloc_log.h"
+
+#include <cstdio>
+#include <cstdlib>
+#include <cstring>
+#include <ctime>
+#include <mutex>
+
+#include <execinfo.h>
+
+namespace cuvslam::cuda {
+namespace {
+
+constexpr int kMaxFrames = 12;
+
+// Intentionally leaked: LogFree runs from destructors of static-lifetime
+// objects, which may outlive any namespace-scope static here.
+struct State {
+  std::mutex mu;
+  FILE* file = nullptr;
+  bool initialized = false;
+};
+
+State& state() {
+  static State* s = new State;
+  return *s;
+}
+
+int64_t now_us() {
+  timespec ts;
+  clock_gettime(CLOCK_MONOTONIC, &ts);
+  return static_cast<int64_t>(ts.tv_sec) * 1000000 + ts.tv_nsec / 1000;
+}
+
+// Executable mappings let offline tooling turn absolute PCs into
+// <module, file-offset> pairs for addr2line.
+void dump_maps_locked() {
+  State& s = state();
+  if (!s.file) {
+    return;
+  }
+  if (FILE* maps = fopen("/proc/self/maps", "r")) {
+    char line[512];
+    while (fgets(line, sizeof(line), maps)) {
+      if (strstr(line, " r-xp ")) {
+        fprintf(s.file, "M,%s", line);
+      }
+    }
+    fclose(maps);
+  }
+  fflush(s.file);
+}
+
+void close_log() {
+  State& s = state();
+  std::lock_guard<std::mutex> lock(s.mu);
+  if (s.file) {
+    dump_maps_locked();
+    fclose(s.file);
+    s.file = nullptr;
+  }
+}
+
+FILE* file_locked() {
+  State& s = state();
+  if (!s.initialized) {
+    s.initialized = true;
+    if (const char* path = getenv("CUVSLAM_ALLOC_LOG")) {
+      s.file = fopen(path, "w");
+      if (s.file) {
+        fprintf(s.file, "#cuvslam-alloc-log,v1\n");
+        dump_maps_locked();
+        atexit(close_log);
+      }
+    }
+  }
+  return s.file;
+}
+
+}  // namespace
+
+void LogAlloc(const void* ptr, size_t bytes, const char* kind) {
+  State& s = state();
+  std::lock_guard<std::mutex> lock(s.mu);
+  FILE* f = file_locked();
+  if (!f || !ptr) {
+    return;
+  }
+  void* frames[kMaxFrames];
+  const int n = backtrace(frames, kMaxFrames);
+  fprintf(f, "A,%lld,%p,%zu,%s", static_cast<long long>(now_us()), ptr, bytes, kind);
+  for (int i = 1; i < n; ++i) {  // frame 0 is LogAlloc itself
+    fprintf(f, ",%p", frames[i]);
+  }
+  fputc('\n', f);
+  fflush(f);  // allocation-rate writes only; keeps the journal crash-consistent
+}
+
+void LogFree(const void* ptr) {
+  State& s = state();
+  std::lock_guard<std::mutex> lock(s.mu);
+  FILE* f = file_locked();
+  if (!f || !ptr) {
+    return;
+  }
+  fprintf(f, "F,%lld,%p\n", static_cast<long long>(now_us()), ptr);
+}
+
+}  // namespace cuvslam::cuda
diff --color -ruN a/libs/cuda_modules/alloc_log.h b/libs/cuda_modules/alloc_log.h
--- a/libs/cuda_modules/alloc_log.h	1970-01-01 05:30:00.000000000 +0530
+++ b/libs/cuda_modules/alloc_log.h	2026-07-04 13:50:40.086026977 +0530
@@ -0,0 +1,22 @@
+
+/*
+ * Instrumentation-only allocation journal (profiling; not part of upstream cuVSLAM).
+ *
+ * Records every device allocation/free made by the cuda_modules wrappers, with
+ * a host backtrace per allocation, so post-processing can attribute device
+ * addresses in NVBit traces to the owning data structure (addr2line against a
+ * -g build). Enabled only when CUVSLAM_ALLOC_LOG=<path> is set in the
+ * environment; otherwise each call is a mutex lock + one branch on a cached
+ * flag, on allocation paths only (never per-access, never per-frame-pixel).
+ */
+
+#pragma once
+
+#include <cstddef>
+
+namespace cuvslam::cuda {
+
+void LogAlloc(const void* ptr, size_t bytes, const char* kind);
+void LogFree(const void* ptr);
+
+}  // namespace cuvslam::cuda
